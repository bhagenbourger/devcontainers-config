{
  "name": "Jugobox Dev Container",
  "build": {
    "dockerfile": "docker/Dockerfile"
  },
  "remoteUser": "vscode",
  "forwardPorts": [6600, 6680],
  "mounts": [
    "source=.devcontainer/mopidy/mopidy.conf,target=/home/vscode/.config/mopidy/mopidy.conf,type=bind,consistency=cached",
    "source=.devcontainer/mopidy/config.json,target=/home/vscode/.config/mopidy/config.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}/Music,target=/home/vscode/music/,type=bind,consistency=cached"
  ],
  "postCreateCommand": ".devcontainer_config/scripts/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "ms-python.vscode-pylance"
      ]
    }
  }
}